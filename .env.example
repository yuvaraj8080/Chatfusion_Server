# Server Configuration Template
# Fill in the following variables to correctly initialization the server.

# Database
DB_URL=mongodb://localhost:27017/chatfusion

# Port
PORT=3000

# Razorpay (Optional - if using payments)
RAZOR_PAY_KEY_ID=your_razorpay_key_id
RAZOR_PAY_KEY_SECRET=your_razorpay_key_secret

# Geocoder (Optional - if using location services)
GEOCODER_PROVIDER=openstreetmap
GEOCODER_API_KEY=your_geocoder_api_key

# JWT (Required for authentication)
ACCESS_TOKEN_SECRET=your_super_secret_key
ACCESS_TOKEN_EXPIRES_IN=30d

# MSG91 (Required for OTP)
MSG91TEMPLATEID=your_msg91_template_id
MSG91AUTHKEY=your_msg91_auth_key
